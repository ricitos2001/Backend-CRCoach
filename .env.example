# =============================================================================
# CRCoach - Backend Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials to version control
# =============================================================================

# ===========================
# DATABASE (PostgreSQL)
# ===========================
# Local development
PGHOST=postgres-db
PGPORT=5432
PGDATABASE=crcoach_dev
PGUSER=crcoach_user
PGPASSWORD=crcoach_password_dev

# For production (Neon example):
# PGHOST=ep-xxxxxxx-pooler.c-3.eu-central-1.aws.neon.tech
# PGDATABASE=crcoach_prod
# PGUSER=neondb_owner
# PGPASSWORD=your_secure_password_here

# ===========================
# APPLICATION Server
# ===========================
PORT=8080
NODE_ENV=development

# ===========================
# EMAIL (SMTP via Brevo)
# ===========================
# Get credentials from: https://www.brevo.com/
SPRING_HOST=smtp-relay.brevo.com
SPRING_MAIL_USERNAME=your_email@smtp-brevo.com
SPRING_MAIL_PASSWORD=xsmtpsib-your_token_here
BREVO_API_KEY=xkeysib-your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@crcoach.org
BREVO_SENDER_NAME=CRCoach

# ===========================
# CLASH ROYALE API
# ===========================
# Get credentials from: https://developer.clashroyale.com/
CLASH_ROYALE_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGci...your_jwt_token_here
CLASH_ROYALE_API_URL=https://api.clashroyale.com/v1

# ===========================
# FRONTEND URL (CORS)
# ===========================
# For local development
APP_FRONTEND_BASE_URL=http://localhost

# ===========================
# SECURITY (Optional)
# ===========================
# Only uncomment and set if needed
# JWT_SECRET=your_jwt_secret_key_here
# JWT_EXPIRATION_MS=86400000

